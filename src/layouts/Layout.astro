---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "建中 110 作業列表" } = Astro.props;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/ck110icon.jpg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-3R59NWGFGP"
    ></script>
    <script>
      // @ts-nocheck
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-3R59NWGFGP");
    </script>
  </head>
  <body
    class="min-h-screen content-center relative bg-slate-50 text-slate-800 antialiased selection:bg-blue-200"
  >
    <div
      class="fixed inset-0 z-[-1] bg-[radial-gradient(ellipse_at_top,var(--tw-gradient-stops))] from-blue-50/50 via-slate-50 to-slate-50"
    >
    </div>
    <slot />
  </body>
</html>
